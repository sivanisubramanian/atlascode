rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    
    function isUser(userId) {
      return request.auth.uid == userId;
    }

    // Users collection - allow users to read/write their own data, read all for lookup
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && isUser(userId);
    }

    // Classes collection - teachers can create and read their classes, students can read
    match /classes/{classId} {
      allow read: if isAuth();
      allow create: if isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
      allow update, delete: if isAuth() && resource.data.teacherId == request.auth.uid;
    }

    // Student progress - students can read/write their own, teachers can read their students'
    match /student_progress/{studentId} {
      allow read: if isAuth() && (isUser(studentId) || get(/databases/$(database)/documents/users/$(studentId)).data.teacherId == request.auth.uid);
      allow write: if isAuth() && isUser(studentId);
    }
  }
}
